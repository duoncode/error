{
	"name": "celemas/error",
	"description": "Error handling PSR-15 middleware",
	"type": "library",
	"license": "MIT",
	"homepage": "https://celemas.dev/error",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"autoload": {
		"psr-4": {
			"Celemas\\Error\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Error\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": "^8.5",
		"psr/http-message": "^1.1 || ^2.0",
		"psr/http-server-handler": "^1.0",
		"psr/http-server-middleware": "^1.0",
		"psr/http-factory": "^1.0"
	},
	"require-dev": {
		"celemas/dev": "^4.1",
		"celemas/log": "dev-main",
		"nyholm/psr7": "^1.8",
		"nyholm/psr7-server": "^1.0"
	},
	"scripts": {
		"test": [
			"composer docstest",
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md docs/",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md docs/",
		"coverage:test": "./vendor/bin/phpunit --testdox --coverage-clover=clover.xml --coverage-text --coverage-php=coverage/cover.php --colors=always",
		"coverage:analyze": "./vendor/bin/coverlyzer coverage/cover.php",
		"coverage": [
			"composer coverage:test",
			"composer coverage:analyze"
		],
		"ci": [
			"composer docstest",
			"composer coverage",
			"composer types"
		],
		"docstest": "./vendor/bin/docs-test-runner ./docs/code"
	}
}
